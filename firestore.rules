rules_version = '2';

// ============================================================
// Reglas de seguridad de Firestore para el sistema de docente/
// alumno. Pega este contenido en la consola de Firebase:
// Firestore Database → Reglas → sustituir todo → Publicar.
//
// Nivel de seguridad: "razonable para un aula no adversarial", no
// de nivel bancario. Los docentes tienen cuentas reales (correo +
// contraseña); los alumnos solo tienen una clave de 6+ caracteres
// (son menores, sin más datos). Cualquier sesión (incluida una
// anónima) puede LEER un documento concreto de "students" para
// poder validar una clave tecleada, pero nadie salvo el docente
// dueño puede LISTAR la colección completa (no se puede "explorar"
// el listado de alumnos sin ser su docente).
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwnerTeacher(teacherId) {
      return signedIn() && request.auth.uid == teacherId;
    }

    match /teachers/{teacherId} {
      allow read, write: if isOwnerTeacher(teacherId);
    }

    match /classes/{classId} {
      allow get: if signedIn();
      allow list: if signedIn() && resource.data.teacherId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if isOwnerTeacher(resource.data.teacherId);
    }

    // Histórico opcional del Generador de Unidad Didáctica: un registro
    // ligero por cada paquete compilado, solo visible/creable por el
    // propio docente. La herramienta funciona igual sin esta colección
    // (uso sin login), así que no bloquea nada si no se publica.
    match /udiHistorial/{entryId} {
      allow list: if signedIn() && resource.data.teacherId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.teacherId == request.auth.uid;
      allow delete: if isOwnerTeacher(resource.data.teacherId);
    }

    match /students/{code} {
      allow get: if signedIn();
      allow list: if signedIn() && resource.data.teacherId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.teacherId == request.auth.uid;
      // Cualquier sesión con la clave puede reclamar al alumno, y solo
      // puede tocar authUid y lastLoginAt. Antes la clave quedaba atada
      // al primer dispositivo que la usaba, así que el mismo alumno no
      // podía entrar en clase y en casa: ahora el último dispositivo
      // desde el que entra pasa a ser el activo.
      allow update: if isOwnerTeacher(resource.data.teacherId)
                    || (signedIn()
                        && request.resource.data.diff(resource.data).affectedKeys()
                             .hasOnly(["authUid", "lastLoginAt"]));
      allow delete: if isOwnerTeacher(resource.data.teacherId);

      match /logins/{loginId} {
        allow create: if signedIn()
                       && get(/databases/$(database)/documents/students/$(code)).data.authUid == request.auth.uid;
        allow read: if isOwnerTeacher(get(/databases/$(database)/documents/students/$(code)).data.teacherId);
      }

      match /dailyStats/{statId} {
        allow read, write: if signedIn()
                       && get(/databases/$(database)/documents/students/$(code)).data.authUid == request.auth.uid;
        allow read: if isOwnerTeacher(get(/databases/$(database)/documents/students/$(code)).data.teacherId);
      }

      match /reviewQueue/{itemId} {
        allow read, write: if signedIn()
                       && get(/databases/$(database)/documents/students/$(code)).data.authUid == request.auth.uid;
      }

      match /gamification/{doc} {
        allow read, write: if signedIn()
                       && get(/databases/$(database)/documents/students/$(code)).data.authUid == request.auth.uid;
        allow read: if isOwnerTeacher(get(/databases/$(database)/documents/students/$(code)).data.teacherId);
      }
    }
  }
}
